rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1048576
        && (data.bannerURL == null || (data.bannerURL is string && data.bannerURL.size() <= 1048576))
        && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 30))
        && (data.connections == null || data.connections is list)
        && (data.mutedUsers == null || data.mutedUsers is list)
        && (data.blockedUsers == null || data.blockedUsers is list)
        && data.createdAt == request.time;
    }

    function isValidUserUpdate(existing, incoming) {
      return incoming.diff(existing).affectedKeys().hasOnly([
        'displayName', 'photoURL', 'bannerURL', 'bio', 'phoneNumber', 
        'connections', 'mutedUsers', 'blockedUsers', 'updatedAt'
      ])
      && (incoming.displayName is string && incoming.displayName.size() <= 100)
      && (incoming.photoURL is string && incoming.photoURL.size() <= 1048576)
      && (incoming.bannerURL == null || (incoming.bannerURL is string && incoming.bannerURL.size() <= 1048576))
      && (incoming.bio == null || (incoming.bio is string && incoming.bio.size() <= 500))
      && (incoming.phoneNumber == null || (incoming.phoneNumber is string && incoming.phoneNumber.size() <= 30))
      && (!incoming.diff(existing).affectedKeys().hasAny(['updatedAt']) || incoming.updatedAt == request.time);
    }

    function isValidStory(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'authorPhoto', 'imageUrl', 'createdAt', 'expiresAt'])
        && data.authorId == request.auth.uid
        && data.imageUrl is string && data.imageUrl.size() <= 1000000
        && data.createdAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'likesCount', 'commentsCount', 'createdAt'])
        && data.authorId == request.auth.uid
        && data.content is string && data.content.size() <= 280
        && data.likesCount is number
        && data.commentsCount is number
        && data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'content', 'type', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.content is string && data.content.size() <= 1000000
        && data.type in ['text', 'voice', 'image']
        && data.createdAt == request.time;
    }

    function isValidChat(data) {
      return data.participants.size() >= 2
        && data.participants.size() <= 100
        && request.auth.uid in data.participants;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUserUpdate(existing(), incoming());
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(storyId) && isValidStory(incoming());
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && existing().authorId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrl']);
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && isValidId(messageId) 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && isValidMessage(incoming());
      }
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && (!existing().isPrivate || request.auth.uid in existing().members);
      allow create: if isSignedIn() && isValidId(groupId) 
        && incoming().ownerId == request.auth.uid
        && incoming().members.size() > 0
        && incoming().members[0] == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().ownerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['name', 'description', 'isPrivate', 'members']))
        || (incoming().diff(existing()).affectedKeys().hasOnly(['members']) && request.auth.uid in incoming().members)
      );
    }
  }
}
