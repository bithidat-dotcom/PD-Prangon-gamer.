{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bannerURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "bio": { "type": "string" },
        "connections": { "type": "array" },
        "mutedUsers": { "type": "array" },
        "blockedUsers": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Story": {
      "title": "Story",
      "description": "A vanishing image post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "imageUrl", "createdAt", "expiresAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social post (tweet)",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "A private or public group chat",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array" },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "isPrivate"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message (encrypted)",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice", "image"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "content", "type"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A direct or group chat session",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Public social posts"
    },
    "stories/{storyId}": {
      "schema": "Story",
      "description": "Vanishing user stories"
    },
    "groups/{groupId}": {
      "schema": "Group",
      "description": "Group definitions"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
